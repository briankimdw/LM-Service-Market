generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoinListing {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  category      String
  metal         String?
  year          Int?
  mintMark      String?
  grade         String?
  certification String?
  certNumber    String?
  description   String?  @db.Text
  costBasis     Float?
  askingPrice   Float
  quantity      Int      @default(1)
  featured      Boolean  @default(false)
  sold          Boolean  @default(false)
  images        String   @default("[]") @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sales         Sale[]
}

model AppraisalRequest {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String?
  description   String   @db.Text
  images        String   @default("[]") @db.Text
  contactMethod String   @default("email")
  status        String   @default("new")
  adminNotes    String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String   @db.Text
  excerpt    String?  @db.Text
  coverImage String?  @db.Text
  published  Boolean  @default(false)
  author     String   @default("Admin")
  tags       String   @default("[]") @db.Text
  metaTitle  String?
  metaDesc   String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StoreSettings {
  id                   String  @id @default("default")
  shopName             String  @default("My Coin Shop")
  tagline              String  @default("Your Trusted Local Coin Dealer")
  address              String  @default("123 Main Street")
  city                 String  @default("Springfield")
  state                String  @default("IL")
  zip                  String  @default("62701")
  phone                String  @default("(555) 555-5555")
  email                String  @default("info@coinshop.com")
  heroTitle            String  @default("Buy, Sell & Trade Coins & Precious Metals")
  heroSubtitle         String  @default("Serving collectors and investors for over 25 years")
  aboutText            String  @default("") @db.Text
  ownerBio             String  @default("") @db.Text
  yearsInBusiness      String  @default("25+")
  memberships          String  @default("[]") @db.Text
  logo                 String?  @db.Text
  bannerImage          String?  @db.Text
  isOpen               Boolean @default(true)
  hoursJson            String  @default("[{\"day\":\"Monday\",\"open\":\"9:00 AM\",\"close\":\"5:00 PM\",\"closed\":false},{\"day\":\"Tuesday\",\"open\":\"9:00 AM\",\"close\":\"5:00 PM\",\"closed\":false},{\"day\":\"Wednesday\",\"open\":\"9:00 AM\",\"close\":\"5:00 PM\",\"closed\":false},{\"day\":\"Thursday\",\"open\":\"9:00 AM\",\"close\":\"5:00 PM\",\"closed\":false},{\"day\":\"Friday\",\"open\":\"9:00 AM\",\"close\":\"5:00 PM\",\"closed\":false},{\"day\":\"Saturday\",\"open\":\"10:00 AM\",\"close\":\"3:00 PM\",\"closed\":false},{\"day\":\"Sunday\",\"open\":\"\",\"close\":\"\",\"closed\":true}]") @db.Text
  googleMapsUrl        String  @default("")
  googleMapsEmbed      String  @default("") @db.Text
  socialFacebook       String  @default("")
  socialInstagram      String  @default("")
  socialTwitter        String  @default("")
  autoFetchSpot        Boolean @default(true)
  goldSpotOverride     Float?
  silverSpotOverride   Float?
  platinumSpotOverride Float?
  palladiumSpotOverride Float?
  goldBuyPremium       Float   @default(-5)
  goldSellPremium      Float   @default(5)
  silverBuyPremium     Float   @default(-10)
  silverSellPremium    Float   @default(15)
  platinumBuyPremium   Float   @default(-5)
  platinumSellPremium  Float   @default(10)
  palladiumBuyPremium  Float   @default(-5)
  palladiumSellPremium Float   @default(10)
  googlePlaceId        String  @default("")
  googleApiKey         String  @default("")
  smtpHost             String  @default("")
  smtpPort             String  @default("")
  smtpUser             String  @default("")
  smtpPass             String  @default("")
  smtpFrom             String  @default("")
  ownerMessage         String  @default("") @db.Text
  ownerMessageActive   Boolean @default(false)
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Sale {
  id            String      @id @default(cuid())
  coinListingId String
  coinListing   CoinListing @relation(fields: [coinListingId], references: [id])
  salePrice     Float
  soldAt        DateTime    @default(now())
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())
}

model InquiryReply {
  id          String   @id @default(cuid())
  inquiryId   String
  inquiryType String
  fromAdmin   Boolean  @default(true)
  message     String   @db.Text
  sentTo      String
  sentAt      DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  text      String   @db.Text
  rating    Int      @default(5)
  featured  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Appointment {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String
  date       String
  timeSlot   String
  type       String
  status     String   @default("pending")
  notes      String?  @db.Text
  adminNotes String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AppointmentSettings {
  id               String @id @default("default")
  slotDurationMin  Int    @default(30)
  maxPerSlot       Int    @default(1)
  advanceBookDays  Int    @default(30)
  appointmentTypes String @default("[\"Appraisal\",\"Sell Coins\",\"Buy Consultation\",\"Collection Review\",\"Estate Evaluation\"]") @db.Text
  blockedDates     String @default("[]") @db.Text
}

model WantToBuyItem {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  category    String   @default("Coins")
  priceRange  String?
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id          String    @id @default(cuid())
  name        String
  address     String    @default("")
  phone       String    @default("")
  website     String    @default("")
  webStatus   String    @default("unknown")
  rating      Float?
  reviews     Int       @default(0)
  mapsUrl     String    @default("")
  notes       String    @default("") @db.Text
  status      String    @default("new")
  contactedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Client {
  id              String    @id @default(cuid())
  shopName        String
  ownerName       String    @default("")
  email           String    @default("")
  phone           String    @default("")
  domain          String    @default("")
  plan            String    @default("basic")
  status          String    @default("pending")
  monthlyRate     Float     @default(0)
  startDate       DateTime?
  notes           String    @default("") @db.Text
  siteUrl         String    @default("")
  adminUrl        String    @default("")
  vercelProject   String    @default("")
  lastCheckAt     DateTime?
  lastCheckStatus String    @default("unknown")
  paymentStatus   String    @default("unpaid")
  lastPaidAt      DateTime?
  contactEmail    String    @default("")
  contactPhone    String    @default("")
  stripeCustomerId String   @default("")
  setupFee        Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String   @db.Text
  answer    String   @db.Text
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductRequest {
  id          String   @id @default(cuid())
  name        String
  email       String   @default("")
  productName String
  description String   @default("") @db.Text
  status      String   @default("new")
  adminNotes  String   @default("") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
